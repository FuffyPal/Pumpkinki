{
  "name": "rust-dev-container-podman",
  "build": {
      "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "runArgs": [
    "--userns=keep-id",
    "--security-opt", "label=disable",
    "-v", "/run/user/1000/gnupg:/run/user/1000/gnupg"
  ],
  "mounts": [
    "source=${localEnv:HOME}/.gnupg,target=/home/vscode/.gnupg,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,ro=true",
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,ro=true"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb",
        "gitlab.gitlab-workflow",
        "leonardssh.vscord",
        "esbenp.prettier-vscode",
        "yzhang.markdown-all-in-one",
        "davidanson.vscode-markdownlint"
      ],
      "settings": {
        "rust-analyzer.check.command": "clippy"
      }
    }
  }
}
